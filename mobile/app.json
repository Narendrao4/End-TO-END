{
  "expo": {
    "name": "EndToEnd Mobile",
    "slug": "endtoend-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.endtoend.mobile"
    },
    "android": {
      "useNextNotificationsApi": true,
      "package": "com.endtoend.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
